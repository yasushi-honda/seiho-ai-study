---
import { withBase } from '../lib/urls';

interface Props {
  order: number;
  title: string;
  icon: string;
  summary: string;
  slug: string;
  draft?: boolean;
}

const { order, title, icon, summary, slug, draft = false } = Astro.props;
const orderLabel = String(order).padStart(2, '0');
---

<a
  href={withBase(`topics/${slug}`)}
  class="relative block min-h-[180px] overflow-hidden rounded-2xl border border-border-soft bg-card p-4 text-ink-1 no-underline transition-transform hover:-translate-y-0.5 hover:shadow-card focus-visible:outline-2 focus-visible:outline-accent-1 focus-visible:outline-offset-2 md:p-5"
>
  {
    /* 装飾の有機形（ベージュ→テラコッタ） */
  }
  <span
    aria-hidden="true"
    class="absolute -right-5 -top-5 h-20 w-20 rounded-[50%_40%_60%_50%] bg-accent-2-soft opacity-60"
  ></span>

  <span class="font-display relative text-2xl font-semibold leading-none text-accent-1">
    {orderLabel}
  </span>
  <span class="mt-2 block text-2xl leading-none" aria-hidden="true">{icon}</span>
  <h3 class="font-display mt-2 text-base font-semibold leading-snug">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-ink-2">{summary}</p>

  {
    draft && (
      <span class="absolute right-3 top-3 rounded-full bg-warn-soft px-2 py-0.5 text-[10px] font-semibold tracking-wider text-warn">
        DRAFT
      </span>
    )
  }
  <span aria-hidden="true" class="absolute bottom-4 right-4 text-lg text-accent-1">→</span>
</a>
