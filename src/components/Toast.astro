---
// グローバルなトースト通知。クライアント側で window.__showToast(msg) で呼び出す。
---

<div
  id="toast"
  class="pointer-events-none fixed bottom-6 left-1/2 z-[100] -translate-x-1/2 translate-y-24 rounded-full bg-ink-1 px-6 py-3 text-sm font-semibold text-white opacity-0 shadow-card transition-all duration-300 ease-out"
  role="status"
  aria-live="polite"
  aria-atomic="true"
>
  メッセージ
</div>

<script is:inline>
  (() => {
    const el = document.getElementById('toast');
    if (!el) return;
    let hideTimer;
    window.__showToast = (msg, duration = 2200) => {
      el.textContent = msg;
      el.classList.remove('opacity-0', 'translate-y-24');
      el.classList.add('opacity-100', 'translate-y-0');
      clearTimeout(hideTimer);
      hideTimer = window.setTimeout(() => {
        el.classList.add('opacity-0', 'translate-y-24');
        el.classList.remove('opacity-100', 'translate-y-0');
      }, duration);
    };
  })();
</script>
