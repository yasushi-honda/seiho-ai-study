---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/urls';

interface Link {
  title: string;
  url: string;
  note?: string;
}

interface ResourceSection {
  title: string;
  icon: string;
  description: string;
  links: Link[];
}

const sections: ResourceSection[] = [
  {
    title: '法令・公的ガイドライン',
    icon: '⚖️',
    description: '個人情報・福祉現場における基本ルール',
    links: [
      {
        title: '医療・介護関係事業者における個人情報の適切な取扱いのためのガイダンス（個人情報保護委員会）',
        url: 'https://www.ppc.go.jp/personalinfo/legal/iryoukaigo_guidance/',
        note: '社会福祉施設にも準用される現行ガイダンス',
      },
      {
        title: '個人情報保護法（e-Gov 法令検索）',
        url: 'https://elaws.e-gov.go.jp/document?lawid=415AC0000000057',
        note: '要配慮個人情報・委託など中心条文',
      },
      {
        title: 'ISMAP 政府情報システムのためのセキュリティ評価制度',
        url: 'https://www.ismap.go.jp/',
        note: 'クラウドサービスリスト・選定時の根拠資料',
      },
      {
        title: '厚生労働省 個人情報保護関連ページ',
        url: 'https://www.mhlw.go.jp/stf/seisakunitsuite/bunya/0000027272.html',
        note: 'ガイドライン本体・Q&A',
      },
    ],
  },
  {
    title: 'AI サービス公式',
    icon: '🤖',
    description: '法人契約・データ取扱いは必ず公式ヘルプで確認',
    links: [
      {
        title: 'ChatGPT（OpenAI）',
        url: 'https://chatgpt.com/',
        note: '法人プラン: Business / Enterprise',
      },
      {
        title: 'OpenAI 法人プラン比較',
        url: 'https://openai.com/business/',
        note: '料金・データ取扱いの最新公式情報',
      },
      {
        title: 'Google Gemini',
        url: 'https://gemini.google.com/',
        note: '個人アプリ。Workspace連携で法人利用',
      },
      {
        title: 'Google Workspace with Gemini',
        url: 'https://workspace.google.com/solutions/ai/',
        note: '法人データは学習対象外（デフォルト）',
      },
      {
        title: 'NotebookLM',
        url: 'https://notebooklm.google.com/',
        note: '個人版・出典付き回答。法令検索・施設知識基盤に',
      },
      {
        title: 'NotebookLM Enterprise（Google Cloud）',
        url: 'https://cloud.google.com/products/agent-builder',
        note: 'ISMAP 本登録済。政府・自治体・関連団体の調達対応',
      },
      {
        title: 'Anthropic Claude',
        url: 'https://claude.com/',
        note: '個人プラン・Team・Enterprise',
      },
    ],
  },
  {
    title: '音声・文字起こしツール',
    icon: '🎙️',
    description: '法人契約・データ学習設定は必ず確認',
    links: [
      {
        title: 'Notta',
        url: 'https://www.notta.ai/ja',
        note: '日本語精度・話者識別。法人版を推奨',
      },
      {
        title: 'CLOVA Note（LINE WORKS）',
        url: 'https://clovanote.line.me/',
        note: '日本語特化、要約機能内蔵',
      },
      {
        title: 'Plaud Note',
        url: 'https://www.plaud.ai/',
        note: 'IC レコーダー型、録音→自動連携',
      },
      {
        title: 'ミルモレコーダー（ウェルモ）',
        url: 'https://welmo.co.jp/service/mirumo-recorder/',
        note: '福祉・介護業界特化。SOAP・F-SOAIP テンプレート',
      },
    ],
  },
  {
    title: '福祉×AI 事例・参考記事',
    icon: '📰',
    description: '他自治体・施設の取り組み',
    links: [
      {
        title: '千葉県「いつでも福祉相談サポット」',
        url: 'https://www.pref.chiba.lg.jp/kenshidou/types/welfarechatbot.html',
        note: '生成AI チャットボット（Web/LINE、24時間）',
      },
      {
        title: '厚生労働省「2040 年に向けたサービス提供体制等のあり方に関する中間とりまとめ」',
        url: 'https://www.mhlw.go.jp/stf/newpage_53006.html',
        note: 'ケアプラン・議事録への生成 AI 活用が明記',
      },
      {
        title: '宮城県「生成 AI で業務効率化」NotebookLM 活用事例',
        url: 'https://www.pref.miyagi.jp/documents/41848/2511_45.pdf',
        note: '自治体側の運用知見',
      },
    ],
  },
  {
    title: '学習リソース（理解を深めたい方へ）',
    icon: '📚',
    description: '時間があるときに目を通せる素材',
    links: [
      {
        title: 'デジタル庁「テキスト生成 AI 利活用におけるリスクへの対策ガイドブック」',
        url: 'https://www.digital.go.jp/resources/govai-guidebook',
        note: '行政側のリスク対策の考え方',
      },
      {
        title: 'IPA「ChatGPT 等の生成 AI に関する技術解説」',
        url: 'https://www.ipa.go.jp/security/vuln/index.html',
        note: '技術的なセキュリティ視点',
      },
    ],
  },
];
---

<Layout title="参考リンク" description="生保AIスタディの参考リンク集。法令・公的ガイドライン、AI サービス公式、文字起こしツール、福祉×AI事例。">
  <section class="container-page py-10 md:py-16">
    <header class="mb-8">
      <span class="font-display mb-2 block text-xs font-semibold uppercase tracking-widest text-accent-1">
        Resources
      </span>
      <h1 class="font-display text-3xl font-semibold leading-tight md:text-4xl">参考リンク</h1>
      <p class="mt-3 text-base text-ink-2">
        研修内容を深掘りしたい方、施設で展開する方のための一次資料リンク集。
      </p>
    </header>

    <div class="mb-8 rounded-xl border-l-4 border-warn bg-warn-soft p-4 text-sm leading-relaxed text-ink-1">
      <p class="m-0">
        <strong>⚠ 注意：</strong>
        外部リンクは2026年6月時点の公開URLです。リンク切れ・サービス停止の可能性があります。
        AI サービスの料金・仕様は変動するため、契約前に必ず最新の公式情報をご確認ください。
      </p>
    </div>

    {sections.map((s) => (
      <section class="mb-10">
        <h2 class="font-display mb-2 text-xl font-semibold md:text-2xl">
          <span aria-hidden="true">{s.icon}</span> {s.title}
        </h2>
        <p class="mb-4 text-sm text-ink-2">{s.description}</p>

        <ul class="space-y-2">
          {s.links.map((l) => (
            <li class="rounded-xl border border-border-soft bg-card p-3 md:p-4">
              <a
                href={l.url}
                target="_blank"
                rel="noopener noreferrer"
                class="font-display block text-base font-semibold text-accent-1 underline-offset-2 hover:underline"
              >
                {l.title} ↗
              </a>
              {l.note && (
                <p class="mt-1 text-xs leading-relaxed text-ink-2">{l.note}</p>
              )}
              <p class="mt-1 break-all font-mono text-[10px] text-ink-3">{l.url}</p>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <div class="mt-12 rounded-2xl border-2 border-dashed border-accent-1 bg-bg-deep p-6 text-center">
      <p class="font-display mb-2 text-base font-semibold">良いリンクが他にあれば</p>
      <p class="text-sm text-ink-2">研修当日や事後に教えていただければ追加します。</p>
      <a
        href={withBase('')}
        class="mt-4 inline-block rounded-full bg-accent-1 px-5 py-2.5 text-sm font-semibold text-white no-underline hover:bg-accent-1-deep"
      >
        トップへ戻る
      </a>
    </div>
  </section>
</Layout>
