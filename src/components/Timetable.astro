---
import { TIMETABLE } from '../lib/timetable';
---

<div
  class="rounded-2xl border border-border-soft bg-surface p-4 shadow-card md:p-6"
  role="list"
  aria-label="当日の進行表"
>
  {
    TIMETABLE.map((slot, i) => (
      <div
        class={`grid grid-cols-[80px_1fr] gap-4 py-3 ${
          i < TIMETABLE.length - 1 ? 'border-b border-dashed border-border-soft' : ''
        } ${slot.break ? 'opacity-60' : ''}`}
        role="listitem"
      >
        <span class="font-display text-sm font-semibold text-accent-1">{slot.time}</span>
        <div>
          <strong class="block text-ink-1">{slot.title}</strong>
          <span class="text-sm text-ink-2">{slot.description}</span>
        </div>
      </div>
    ))
  }
</div>
